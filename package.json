{
  "name": "clinni",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema de gestão para clínicas e consultórios",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:auth": "node scripts/check-require-role.mjs",
    "lint:memed": "node scripts/check-memed-frontend-secrets.mjs",
    "scan:memed-keys": "node scripts/scan-bundle-for-memed-keys.mjs",
    "verify:memed-acceptance": "node scripts/verify-memed-acceptance.mjs",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm lint && pnpm typecheck",
    "prepare": "git config core.hooksPath scripts/git-hooks 2>/dev/null || exit 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration",
    "test:contract": "vitest run tests/contract",
    "test:e2e": "playwright test",
    "test:visual": "playwright test tests/e2e/responsive-snapshots.spec.ts",
    "test:visual:update": "playwright test tests/e2e/responsive-snapshots.spec.ts --update-snapshots",
    "test:coverage": "vitest run --coverage",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:diff": "supabase db diff",
    "supabase:gen-types": "supabase gen types typescript --local > src/lib/db/generated/types.ts",
    "seed:tuss": "tsx --env-file=.env.local scripts/seed-tuss.ts",
    "seed:tuss:22": "tsx --env-file=.env.local scripts/seed-tuss.ts --table 22",
    "seed:tuss:19": "tsx --env-file=.env.local scripts/seed-tuss.ts --table 19",
    "seed:tuss:20": "tsx --env-file=.env.local scripts/seed-tuss.ts --table 20",
    "seed:tuss:all": "tsx --env-file=.env.local scripts/seed-tuss.ts --table all",
    "seed:tuss:prod:22": "tsx --env-file=.env.production.local scripts/seed-tuss.ts --table 22",
    "seed:tuss:prod:19": "tsx --env-file=.env.production.local scripts/seed-tuss.ts --table 19",
    "seed:tuss:prod:20": "tsx --env-file=.env.production.local scripts/seed-tuss.ts --table 20",
    "seed:tuss:prod:all": "tsx --env-file=.env.production.local scripts/seed-tuss.ts --table all",
    "seed:tuss:audit-odonto": "tsx --env-file=.env.local scripts/tuss-odonto-audit.ts",
    "seed:tiss-domains": "tsx --env-file=.env.local scripts/seed-tiss-domains.ts",
    "seed:cid10": "tsx --env-file=.env.local scripts/seed-cid10.ts",
    "seed:cid10:prod": "tsx --env-file=.env.production.local scripts/seed-cid10.ts",
    "seed:cid10:dryrun": "tsx scripts/seed-cid10-dryrun.ts",
    "seed:demo": "tsx --env-file=.env.local supabase/seed/demo-tenant.ts",
    "simulate:webhook": "tsx --env-file=.env.local scripts/simulate-ghl-webhook.ts",
    "bench:webhook": "tsx --env-file=.env.local scripts/bench-webhook.ts",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yaml,yml}\""
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "^3.4.4",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "@upstash/qstash": "^2.7.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.38.0",
    "ics": "^3.12.0",
    "lucide-react": "^1.8.0",
    "next": "14.2.5",
    "node-forge": "^1.4.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "^3.8.1",
    "resend": "^3.5.0",
    "tailwind-merge": "^3.5.0",
    "xml-crypto": "^6.1.2",
    "xmlbuilder2": "^4.0.3",
    "xmllint-wasm": "^5.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.2",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.14.10",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^1.6.0",
    "adm-zip": "^0.5.17",
    "autoprefixer": "^10.4",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "eslint-config-prettier": "^9.1.0",
    "msw": "^2.3.4",
    "postcss": "^8.4",
    "prettier": "^3.3.2",
    "supabase": "^2.92.0",
    "tailwindcss": "^3.4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.16.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "yaml": "^2.8.3"
  },
  "packageManager": "pnpm@9.5.0"
}
