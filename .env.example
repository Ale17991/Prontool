# Next.js
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
# Local: run `supabase start` and copy values from its output
# Production: from Supabase dashboard (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=PLACEHOLDER_http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=PLACEHOLDER_replace_with_anon_key
SUPABASE_SERVICE_ROLE_KEY=PLACEHOLDER_replace_with_service_role_key
SUPABASE_JWT_SECRET=PLACEHOLDER_replace_with_jwt_secret
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Patient data encryption (32-byte hex for pgcrypto symmetric encryption)
# Generate with: openssl rand -hex 32
PATIENT_DATA_ENCRYPTION_KEY=PLACEHOLDER_64_hex_chars

# Upstash QStash (create account at upstash.com → QStash)
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=PLACEHOLDER_qstash_token
QSTASH_CURRENT_SIGNING_KEY=PLACEHOLDER_current_signing_key
QSTASH_NEXT_SIGNING_KEY=PLACEHOLDER_next_signing_key

# Resend (create account at resend.com, verify domain)
RESEND_API_KEY=PLACEHOLDER_resend_api_key
RESEND_FROM=alertas@dev.homio.com.br

# GHL (per-tenant secret is stored encrypted in tenant_ghl_config)
# This is only the dev fallback used by the local simulator script.
GHL_DEV_WEBHOOK_SECRET=dev-shared-secret

# GoHighLevel Marketplace OAuth 2.0 (feature 008)
# Created at https://marketplace.gohighlevel.com → My Apps → New App.
# REDIRECT_URI must match exactly the value registered in the app config.
# SCOPES is comma-separated; check spec.md FR-002 / quickstart.md for the
# required set. Read ONLY by src/lib/integrations/ghl/oauth/env.ts.
GHL_CLIENT_ID=PLACEHOLDER_ghl_marketplace_client_id
GHL_CLIENT_SECRET=PLACEHOLDER_ghl_marketplace_client_secret
GHL_REDIRECT_URI=http://localhost:3000/api/oauth/ghl/callback
GHL_SCOPES=contacts.readonly,contacts.write,custom-fields.readonly,custom-fields.write,locations.readonly,opportunities.write,webhooks.readonly,webhooks.write

# HMAC shared secret for INSTALL/UNINSTALL marketplace webhooks (one per app,
# not per tenant). See research.md item 3 — header name and algorithm may need
# verification against current GHL Marketplace docs before launch.
GHL_MARKETPLACE_SHARED_SECRET=PLACEHOLDER_marketplace_hmac_secret

# JWKS URL for verifying SSO context tokens (US5). Public endpoint — no secret.
# Used only when /api/sso/ghl is exercised; safe to leave as default in dev.
GHL_SSO_JWKS_URL=https://services.leadconnectorhq.com/.well-known/jwks.json

# Platform operator (for LGPD anonymize endpoint and TUSS seed admin ops)
PLATFORM_OPERATOR_TOKEN=PLACEHOLDER_random_long_secret

# Cloudflare Turnstile — captcha invisible, LGPD-friendly, sem cookies (feature 017)
# Gere no painel Cloudflare: https://dash.cloudflare.com → Turnstile → Add Site
# Em dev local, use sitekeys de teste públicas da Cloudflare:
#   1x00000000000000000000AA = sempre passa (use por padrao em dev)
#   2x00000000000000000000AB = sempre falha (UX de erro)
#   3x00000000000000000000FF = sempre renderiza challenge (UX de desafio visivel)
# Secrets correspondentes em dev:
#   1x0000000000000000000000000000000AA / 2x... / 3x...
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Vercel Cron (feature 018 — motor de lembretes)
# Compartilhe entre vercel.json e o handler /api/cron/send-reminders.
# Gere com: openssl rand -base64 32
CRON_SECRET=PLACEHOLDER_dev_secret

# Observability
LOG_LEVEL=info

# Feature flags (telas em desenvolvimento — visíveis em dev, ocultas em prod)
# Default: true em dev/test, false em prod (controlado por NODE_ENV em
# src/lib/feature-flags.ts). Setar explicitamente "true" / "false" pra
# forçar o estado em qualquer ambiente.
NEXT_PUBLIC_FEATURE_DESPESAS=false
NEXT_PUBLIC_FEATURE_ANAMNESE=false
NEXT_PUBLIC_FEATURE_RELATORIOS=false
NEXT_PUBLIC_FEATURE_COMISSOES=false
